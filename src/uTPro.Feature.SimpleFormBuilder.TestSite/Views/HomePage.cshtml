@using Umbraco.Extensions
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
	Layout = null;
	// Non-generic view so it compiles regardless of generated models (the fresh
	// PostgreSQL test database has no HomePage document type yet). Reads the form
	// alias from the "form" property generically.
	var formAlias = Model?.Value<string>("form");
}
@if (!string.IsNullOrWhiteSpace(formAlias))
{
	@await Component.InvokeAsync("uTProSimpleForm", new { alias = formAlias })
}
