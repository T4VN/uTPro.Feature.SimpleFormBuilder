@* Form Step divider — renders a visual step separator *@
@using uTPro.Feature.SimpleFormBuilder.Helpers
@model uTPro.Feature.SimpleFormBuilder.Models.FormFieldViewModel
@{
    var h = new FieldHelper(Model, ViewData);
    var title = h.L(h.Attr("title", Model.Label ?? "Next Step"));
}

<div class="uTProForm-step">
    <h3 class="uTProForm-step-title">@title</h3>
    <hr class="uTProForm-step-divider" />
</div>
