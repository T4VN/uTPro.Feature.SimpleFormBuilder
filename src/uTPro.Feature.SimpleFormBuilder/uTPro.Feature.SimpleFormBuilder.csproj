<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <!-- net9.0 -> Umbraco 16, net10.0 -> Umbraco 17 & 18 -->
    <TargetFrameworks>net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>

    <!-- NuGet package metadata -->
    <PackageId>uTPro.Feature.SimpleFormBuilder</PackageId>
    <Title>uTPro Simple Form Builder for Umbraco (16, 17, 18)</Title>
    <Version>2.0.1</Version>
    <Authors>T4VN</Authors>
    <Company>T4VN</Company>
    <Description>Lightweight form builder for Umbraco 16, 17 and 18 - create, manage, and render dynamic forms from the backoffice. Supports 19+ field types, groups/columns layout, client-side validation, sensitive data encryption, multi-language, and custom field extensibility. Runs on SQL Server, SQLite and PostgreSQL.</Description>
    <PackageTags>umbraco;umbraco-marketplace;form;form-builder;umbraco-plugin;cms;postgresql;sqlite;sql-server</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/T4VN/uTPro.Feature.SimpleFormBuilder</PackageProjectUrl>
    <RepositoryUrl>https://github.com/T4VN/uTPro.Feature.SimpleFormBuilder</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageIcon>icon.png</PackageIcon>
    <PackageReleaseNotes>v2.0.1: Fix encode attribute, and renamed front-end CSS class prefix from "sf" to "uTProForm" (e.g. .sf -> .uTProForm, .sf-error -> .uTProForm-error) and JavaScript hooks window.__sfBeforeSubmit/__sfAfterSubmit to window.__uTProFormBeforeSubmit/__uTProFormAfterSubmit for clearer, collision-free naming. BREAKING: sites that target the old .sf* CSS selectors or use the old window.__sf* hooks must update accordingly. v2.0.0: Cross-database support (SQL Server, SQLite and PostgreSQL). Migration now creates JSON columns via SpecialDbTypes.NVARCHARMAX instead of the SQL Server-only NTEXT, and all data access uses NPoco strongly-typed queries so identifiers are quoted per provider. No schema change for existing databases. v1.0.0: Initial release. Form builder for Umbraco 16, 17 and 18 (multi-target net9.0/net10.0) with groups/columns layout, 19 built-in field types + custom field extension point, client-side validation, sensitive-data encryption, import/export, copy/paste, Form Picker property editor, and public submit/render/entries APIs.</PackageReleaseNotes>

    <!-- Serve wwwroot at the site root so App_Plugins/simple-form (backoffice manifest)
         and uTPro/simple-form (front-end assets) resolve at their declared absolute paths. -->
    <StaticWebAssetBasePath>/</StaticWebAssetBasePath>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageOutputPath>..\..\Build</PackageOutputPath>
  </PropertyGroup>

  <!-- Umbraco 16 (runs on .NET 9) -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0'">
    <PackageReference Include="Umbraco.Cms" Version="[16.0.0, 17.0.0)" />
    <PackageReference Include="Microsoft.AspNetCore.DataProtection" Version="9.*" />
  </ItemGroup>

  <!-- Umbraco 17 and 18 (run on .NET 10) -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Umbraco.Cms" Version="[17.0.0, 19.0.0)" />
    <PackageReference Include="Microsoft.AspNetCore.DataProtection" Version="10.*" />
  </ItemGroup>

  <!-- Include README, icon and marketplace manifest in the NuGet package -->
  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\icon.png" Pack="true" PackagePath="\" />
    <None Include="..\..\umbraco-marketplace.json" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>