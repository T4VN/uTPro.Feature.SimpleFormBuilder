{
  "name": "uTPro.SimpleForm",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "section",
      "alias": "uTPro.Section.Form",
      "name": "uTPro Form Section",
      "weight": 50,
      "meta": {
        "label": "#simpleForm_title",
        "pathname": "utpro-form"
      }
    },
    {
      "type": "sectionSidebarApp",
      "alias": "uTPro.SimpleForm.Sidebar",
      "name": "uTPro Form Sidebar",
      "element": "/App_Plugins/simple-form/sidebar.js",
      "elementName": "utpro-simple-form-sidebar",
      "weight": 100,
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "uTPro.Section.Form"
        }
      ]
    },
    {
      "type": "dashboard",
      "alias": "uTPro.SimpleForm.Dashboard",
      "name": "uTPro Form Dashboard",
      "element": "/App_Plugins/simple-form/index.js",
      "elementName": "utpro-simple-form-dashboard",
      "weight": 10,
      "meta": {
        "label": "#simpleForm_title",
        "pathname": "overview"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "uTPro.Section.Form"
        }
      ]
    },
    {
      "type": "localization",
      "alias": "uTPro.SimpleForm.Localize.EnUS",
      "name": "Simple Form English",
      "js": "/App_Plugins/simple-form/lang/en-us.js",
      "meta": { "culture": "en-US" }
    }
  ]
}
