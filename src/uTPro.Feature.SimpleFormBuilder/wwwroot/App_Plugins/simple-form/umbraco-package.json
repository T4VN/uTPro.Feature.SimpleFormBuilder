{
  "name": "uTPro Simple Form Builder",
  "version": "3.1.0",
  "extensions": [
    {
      "type": "section",
      "alias": "uTPro.Section.Form",
      "name": "uTPro Form Section",
      "weight": 50,
      "meta": {
        "label": "#simpleForm_title",
        "pathname": "utpro-form"
      }
    },
    {
      "type": "sectionSidebarApp",
      "alias": "uTPro.SimpleForm.Sidebar",
      "name": "uTPro Form Sidebar",
      "element": "/App_Plugins/simple-form/sidebar.js",
      "elementName": "utpro-simple-form-sidebar",
      "weight": 100,
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "uTPro.Section.Form"
        }
      ]
    },
    {
      "type": "dashboard",
      "alias": "uTPro.SimpleForm.Dashboard",
      "name": "uTPro Form Dashboard",
      "element": "/App_Plugins/simple-form/index.js",
      "elementName": "utpro-simple-form-dashboard",
      "weight": 10,
      "meta": {
        "label": "#simpleForm_title",
        "pathname": "overview"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "uTPro.Section.Form"
        }
      ]
    },
    {
      "type": "localization",
      "alias": "uTPro.SimpleForm.Localize.EnUS",
      "name": "Simple Form English",
      "js": "/App_Plugins/simple-form/lang/en-us.js",
      "meta": { "culture": "en-US" }
    },
    {
      "type": "propertyEditorUi",
      "alias": "uTPro.SimpleForm.FormPicker",
      "name": "uTPro Form Picker",
      "element": "/App_Plugins/simple-form/property-editor/form-picker.element.js",
      "elementName": "utpro-form-picker",
      "meta": {
        "label": "uTPro Form Picker",
        "icon": "icon-list",
        "group": "pickers",
        "propertyEditorSchemaAlias": "uTPro.SimpleForm.FormPickerValue",
        "settings": {
          "properties": [
            {
              "alias": "allowedForms",
              "label": "Allowed forms",
              "description": "Narrow this picker to a fixed set of forms. The 'Show in content picker' rule still applies, so a ticked form only appears in Content if it also has 'Show in content picker' enabled. Leave empty to show every form that has 'Show in content picker' enabled.",
              "propertyEditorUiAlias": "uTPro.SimpleForm.FormListConfig"
            }
          ]
        }
      }
    },
    {
      "type": "propertyEditorUi",
      "alias": "uTPro.SimpleForm.FormListConfig",
      "name": "uTPro Form List Config",
      "element": "/App_Plugins/simple-form/property-editor/form-list-config.element.js",
      "elementName": "utpro-form-list-config",
      "meta": {
        "label": "uTPro Form List",
        "icon": "icon-list",
        "group": "pickers"
      }
    }
  ]
}
